                  <Label alignment="CENTER_RIGHT" contentDisplay="RIGHT" text="Via" GridPane.halignment="CENTER" GridPane.rowIndex="3" />
                  <Label alignment="CENTER_RIGHT" contentDisplay="RIGHT" text="Numero" GridPane.halignment="CENTER" GridPane.rowIndex="4" />
