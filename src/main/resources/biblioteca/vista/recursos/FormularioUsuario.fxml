               <font>
                  <Font size="24.0" />
               </font>
            </Label>
            <GridPane alignment="TOP_RIGHT" hgap="10.0" vgap="8.0">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
