                  <TextField fx:id="txtNombre" style="-fx-background-radius: 20;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <TextField fx:id="txtEmail" style="-fx-background-radius: 20;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <TextField fx:id="txtVia" style="-fx-background-radius: 20;" GridPane.columnIndex="1" GridPane.rowIndex="3" />
